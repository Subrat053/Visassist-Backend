NODE_ENV=development
PORT=5000
APP_NAME=Visaassist
MONGODB_URI=mongodb://127.0.0.1:27017/y_axis

JWT_ACCESS_SECRET=replace_with_secure_secret
JWT_REFRESH_SECRET=replace_with_secure_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000
CORS_ORIGIN=http://localhost:5173

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=example@example.com
SMTP_PASS=your_password
SMTP_FROM_NAME=Visaassist
SMTP_FROM_EMAIL=no-reply@y-axis.com
ADMIN_NOTIFICATION_EMAIL=admin@example.com
ADMIN_NOTIFICATION_CC=
ADMIN_NOTIFICATION_BCC=
MAIL_ENABLED=true
MAIL_LOG_ONLY=false

# Backward-compatible optional sender aliases used by legacy helpers
EMAIL_FROM=no-reply@y-axis.com
